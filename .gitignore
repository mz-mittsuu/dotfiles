# ==================================================
# @file .gitignore
# @brief Git ignore file
# ==================================================

# --------------------------------------------------
# OS / editor temporary files
# --------------------------------------------------
.DS_Store
Thumbs.db
*~
*.swp
*.swo
*.tmp
*.bak
*.orig
*.rej

# --------------------------------------------------
# logs
# --------------------------------------------------
*.log

# --------------------------------------------------
# local / private override files
# --------------------------------------------------
*.local
**/*.local

# --------------------------------------------------
# secrets / credentials
# --------------------------------------------------
.env
.env.*
!.env.example

**/hosts.yml
**/*credential*
**/*secret*
**/*secrets*
**/*token*

# --------------------------------------------------
# histories / runtime state
# --------------------------------------------------
**/.bash_history
**/.zsh_history
**/.lesshst
**/.viminfo
**/.z
**/.zcompdump

# --------------------------------------------------
# caches
# --------------------------------------------------
**/.cache/
**/__pycache__/

# --------------------------------------------------
# SSH and other private directories
# --------------------------------------------------
**/.ssh/

# --------------------------------------------------
# editor / tool generated files
# --------------------------------------------------
.vscode/
.idea/
